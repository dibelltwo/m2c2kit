{
  "name": "@m2c2kit/ema-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "mkdir -p build && cp src/index.html build/index.html && concurrently \"rollup -c --watch --configServe --configPort 3001\" \"tsc --watch\" --names rollup,typescript --prefix-colors auto,red",
    "build": "npm run clean && tsc && rollup -c --configProd",
    "clean": "rimraf build dist .rollup.cache",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap run android",
    "cap:ios": "npx cap run ios"
  },
  "dependencies": {
    "@capacitor/core": "^8.2.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@m2c2kit/assessment-color-dots": "0.8.34",
    "@m2c2kit/assessment-color-shapes": "0.8.34",
    "@m2c2kit/assessment-grid-memory": "0.8.34",
    "@m2c2kit/assessment-symbol-search": "0.8.34",
    "@m2c2kit/db": "0.3.30",
    "@m2c2kit/embedding": "1.0.29",
    "@m2c2kit/session": "0.3.18",
    "@m2c2kit/survey": "0.3.31"
  },
  "devDependencies": {
    "@m2c2kit/build-helpers": "0.3.32",
    "@rollup/plugin-node-resolve": "16.0.3",
    "concurrently": "9.2.1",
    "esbuild": "0.27.3",
    "rimraf": "6.1.3",
    "rollup": "4.59.0",
    "rollup-plugin-esbuild": "6.2.1",
    "rollup-plugin-livereload": "2.0.5",
    "rollup-plugin-serve": "3.0.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  }
}
